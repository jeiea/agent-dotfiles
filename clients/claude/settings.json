  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v terminal-notifier >/dev/null && jq -r '\"terminal-notifier -title \\(.cwd | split(\"/\") | last | @sh) -message \\(.message | @sh) -group \\(.cwd | @sh) -execute \\(\"open -a Cursor \" + (.cwd | @sh) | @sh)\"' | bash"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "permcheck"
          },
          {
            "type": "command",
            "command": "if [ \"$CLAUDE_CODE_ENTRYPOINT\" = \"claude-vscode\" ]; then command -v terminal-notifier >/dev/null && jq -r '\"terminal-notifier -title \\(.cwd | split(\"/\") | last | @sh) -message \\(.tool_name | @sh) -group \\(.cwd | @sh) -execute \\(\"open -a Cursor \" + (.cwd | @sh) | @sh)\"' | bash; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$CLAUDE_CODE_ENTRYPOINT\" = \"claude-vscode\" ]; then command -v terminal-notifier >/dev/null && jq -r '\"terminal-notifier -title \\(.cwd | split(\"/\") | last | @sh) -message \\(\"완료\" | @sh) -group \\(.cwd | @sh) -execute \\(\"open -a Cursor \" + (.cwd | @sh) | @sh)\"' | bash; fi"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$CLAUDE_CODE_ENTRYPOINT\" = \"claude-vscode\" ]; then command -v terminal-notifier >/dev/null && jq -r '\"terminal-notifier -remove \" + (.cwd | @sh)' | bash; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "deno -ERS=homedir -N='raw.githubusercontent.com:443' -- npm:ccusage@latest statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "extraKnownMarketplaces": {},
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "verbose": true,
  "switchModelsOnFlag": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754035295901
  },
  "model": "claude-fable-5[1m]"
}
