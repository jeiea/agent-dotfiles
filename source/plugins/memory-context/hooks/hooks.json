{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT:-$PLUGIN_ROOT}/bin/agent-memory\" hook"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT:-$PLUGIN_ROOT}/bin/agent-memory\" hook"
          }
        ]
      }
    ]
  }
}
