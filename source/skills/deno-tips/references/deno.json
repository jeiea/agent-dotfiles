{
  "fmt": {
    "lineWidth": 100
  },
  "compilerOptions": {
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true
  },
  "tasks": {
    "hooks:install": "deno run --allow-read=deno.json,.git/hooks/ --allow-write=.git/hooks/ jsr:@hongminhee/deno-task-hooks",
    "hooks:pre-commit": "deno run -A npm:lint-staged@^17.0.5 --hide-unstaged --config lint-staged.config.ts",
    "check": {
      "dependencies": [
        "check:fmt",
        "check:lint",
        "check:check",
        "test",
        "publish:check"
      ]
    },
    "check:lint-staged": {
      "dependencies": ["check:check", "test", "publish:check"]
    },
    "check:fmt": "deno fmt --check",
    "check:lint": "deno lint",
    "check:check": "deno check",
    "fmt": "deno fmt",
    "lint": "deno lint --fix",
    "test": "deno test --doc --allow-all",
    "publish:check": "deno publish --dry-run",
    "publish:check-dirty": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "lint-staged": "npm:lint-staged@^17.0.5"
  }
}
